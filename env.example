# ─── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/lifebook.db
SECRET_KEY=REPLACE_WITH_RANDOM_64_CHAR_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Пользователь (единственный) ──────────────────────────────────────────────
APP_USERNAME=admin
APP_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ─── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-REPLACE
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Через запятую, без пробелов
CORS_ORIGINS=https://mylifebook.ru,http://localhost:5173

# ─── Frontend (Vite build arg) ─────────────────────────────────────────────────
VITE_API_BASE_URL=https://mylifebook.ru/api/v1
