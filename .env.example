# ──────────────────────────────────────────
# MyLifeBook — environment variables example
# Copy to .env and fill in real values
# ──────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=mylifebook
POSTGRES_USER=mlb_user
POSTGRES_PASSWORD=change_me_strong_password

# SQLAlchemy async DSN (used by backend)
DATABASE_URL=postgresql+asyncpg://mlb_user:change_me_strong_password@db:5432/mylifebook

# JWT — generate with: openssl rand -hex 32
SECRET_KEY=replace_with_64_char_random_hex
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS (comma-separated)
CORS_ORIGINS=https://mylifebook.ru,https://www.mylifebook.ru

# OpenRouter (optional — AI weekly insights)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# App
DEBUG=false
