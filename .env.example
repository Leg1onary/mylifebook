# ── App ────────────────────────────────────────────────
APP_NAME=MyLifeBook
DEBUG=false
API_V1_PREFIX=/api/v1

# ── Database ───────────────────────────────────────────
# asyncpg DSN (used by SQLAlchemy + Alembic)
DATABASE_URL=postgresql+asyncpg://mlb_user:CHANGE_ME@db:5432/mylifebook

# For docker-compose db service
POSTGRES_DB=mylifebook
POSTGRES_USER=mlb_user
POSTGRES_PASSWORD=CHANGE_ME

# ── Security ───────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ── CORS ───────────────────────────────────────────────
CORS_ORIGINS=https://mylifebook.ru,https://www.mylifebook.ru

# ── OpenRouter AI ──────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-haiku
